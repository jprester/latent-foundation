# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored; `.env.example` is not.

# --- LLM providers (story generation) ---
# At least one of the two below is required for `npm run generate`.

# OpenRouter — default provider. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic — required if you pass `--provider anthropic`. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: site URL sent as the HTTP-Referer header to OpenRouter.
# Defaults to the project's GitHub URL if unset.
OPENROUTER_SITE_URL=

# Optional: default model per provider. The --model flag overrides these.
# Accepts a raw model id (e.g. "claude-opus-4-7", "google/gemini-2.0-flash-exp")
# or one of the script's short aliases. Run `node scripts/generate-story.mjs --help`
# to see the alias list.
# Defaults if unset: ANTHROPIC_MODEL=claude-sonnet-4-6,
#                    OPENROUTER_MODEL=moonshotai/kimi-k2.6
#
# Note: the OpenRouter request sends `reasoning: { enabled: false }`, which
# tells reasoning-capable models (Kimi K2.6, DeepSeek R1, etc.) to skip the
# hidden thinking step and just answer. This means K2.6 works fine with the
# default --max-tokens 4000 even though it's a reasoning model.
ANTHROPIC_MODEL=
OPENROUTER_MODEL=

# --- Thumbnail generation ---
# Required for Fal.ai thumbnail generation (story + backfill modes).
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=
